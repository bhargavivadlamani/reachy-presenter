OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=your_openai_server_url

GEMINI_API_KEY=your-gemini-api-key-here

# Qdrant vector DB URL (default: local Docker instance)
QDRANT_URL=https://<your-cluster>.us-west-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key-here

# Optional: Cohere API key (only needed if using --reranker cohere)
COHERE_API_KEY=your-cohere-api-key-here

# Optional: Vultr Inference API key (only needed if using --gen-provider vultr)
VULTR_API_KEY=your-vultr-api-key-here

# RAG embedding overrides (defaults shown — must match what was used at ingest time)
# RAG_EMBED_PROVIDER=gemini
# RAG_EMBED_MODEL=models/text-embedding-004
# RAG_RERANKER=cohere

# Audience robot — set this on robot 1 (presenter) to enable the audience profile
# AUDIENCE_ROBOT_URL=http://<robot2-ip>:5001
# Optional: change the port the audience server listens on (robot 2 side)
# AUDIENCE_SERVER_PORT=5001

# langsmith
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=reachy-presenter
